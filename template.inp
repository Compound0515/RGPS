@SET COORDFILE coordfile
@SET CELL_A cell_a
@SET CELL_B cell_b
@SET CELL_C cell_c
@SET ANGLE_A angle_a
@SET ANGLE_B angle_b
@SET ANGLE_C angle_c
@SET KPOINTS_A kpoints_a
@SET KPOINTS_B kpoints_b
@SET KPOINTS_C kpoints_c

&GLOBAL
  PROJECT RGPS
  PRINT_LEVEL MEDIUM
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &SUBSYS
    &TOPOLOGY
      COORD_FILE_FORMAT XYZ
      COORD_FILE_NAME ${COORDFILE}
    &END TOPOLOGY
    &CELL
      ABC [angstrom] ${CELL_A} ${CELL_B} ${CELL_C}
      ALPHA_BETA_GAMMA ${ANGLE_A} ${ANGLE_B} ${ANGLE_C}
      PERIODIC XYZ
    &END CELL
    &KIND H
      ELEMENT H
      BASIS_SET TZVP-MOLOPT-PBE-GTH-q1
      POTENTIAL GTH-PBE
    &END KIND
    &KIND O
      ELEMENT O
      BASIS_SET DZVP-MOLOPT-PBE-GTH-q6
      POTENTIAL GTH-PBE
    &END KIND
    &KIND Ti
      ELEMENT Ti
      BASIS_SET DZVP-MOLOPT-PBE-GTH-q12
      POTENTIAL GTH-PBE
    &END KIND
    &KIND Pt
      ELEMENT Pt
      BASIS_SET DZVP-MOLOPT-PBE-GTH-q18
      POTENTIAL GTH-PBE
    &END KIND
  &END SUBSYS

  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL
    CHARGE 0
    MULTIPLICITY 1
    UKS
    &KPOINTS
      SCHEME MONKHORST-PACK ${KPOINTS_A} ${KPOINTS_B} ${KPOINTS_C}
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.0E-12
    &END QS
    &POISSON
      PERIODIC XYZ
      PSOLVER PERIODIC
    &END POISSON
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          PARAMETER_FILE_NAME dftd3.dat
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
    &MGRID
      CUTOFF  500
      REL_CUTOFF  40
    &END MGRID
    &SCF
      MAX_SCF 512
      EPS_SCF 1.0E-06
      IGNORE_CONVERGENCE_FAILURE
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.4
        NBROYDEN 8
      &END MIXING
      &SMEAR
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE 300
      &END SMEAR
      ADDED_MOS 64 64
      &PRINT
        &RESTART
          BACKUP_COPIES 0
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  STRESS_TENSOR ANALYTICAL
  &PRINT
    &STRESS_TENSOR ON
    &END STRESS_TENSOR
    &FORCES ON
    &END FORCES
  &END PRINT
&END FORCE_EVAL
